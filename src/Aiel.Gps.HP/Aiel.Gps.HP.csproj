<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <RootNamespace />
        <AssemblyName>Aiel.Gps.HP</AssemblyName>
        <TargetFramework>net10.0</TargetFramework>
        <IsPackable>true</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <None Include="./README.md" Pack="true" PackagePath="/" />
    </ItemGroup>

    <!-- Reference the source generator project as an analyzer to ensure it is used during compilation of this project. -->
    <ItemGroup>
        <ProjectReference Include="..\..\src\Aiel.Gps.HP.Generators\Aiel.Gps.HP.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="true" PrivateAssets="all" />
    </ItemGroup>

    <!-- Bundle the source generator into this package's analyzers folder. -->
    <ItemGroup>
        <None Include="..\Aiel.Gps.HP.Generators\bin\$(Configuration)\netstandard2.0\Aiel.Gps.HP.Generators.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Aiel.Framework.Abstractions\Aiel.Framework.Abstractions.csproj" />
    </ItemGroup>

</Project>
