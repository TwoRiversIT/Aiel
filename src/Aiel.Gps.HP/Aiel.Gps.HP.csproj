<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace />
		<AssemblyName>Aiel.Gps.HP</AssemblyName>
		<TargetFramework>net10.0</TargetFramework>
		<IsPackable>true</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<None Include="./README.md" Pack="true" PackagePath="/" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Update="ConfigureAwait.Fody">
			<TreatAsUsed>true</TreatAsUsed>
		</PackageReference>
	</ItemGroup>

	<!-- Bundle the source generator into this package's analyzers folder. -->
	<ItemGroup>
		<None Include="..\Aiel.Gps.HP.Generators\bin\$(Configuration)\netstandard2.0\Aiel.Gps.HP.Generators.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Aiel\Aiel.csproj" />
		<!-- Reference the generator as an analyzer -->
		<ProjectReference Include="..\Aiel.Gps.HP.Generators\Aiel.Gps.HP.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
	</ItemGroup>

</Project>
