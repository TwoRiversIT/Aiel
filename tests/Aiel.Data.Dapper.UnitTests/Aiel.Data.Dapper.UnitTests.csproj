<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <RootNamespace />
        <AssemblyName>Aiel.Data.Dapper.UnitTests</AssemblyName>
		<TargetFramework>net10.0</TargetFramework>
		<IsPackable>false</IsPackable>
		<IsTestProject>true</IsTestProject>
	</PropertyGroup>

	<ItemGroup>
        <None Remove="appsettings.Testing.json" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="appsettings.Testing.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.8" />
        <PackageReference Include="Microsoft.Extensions.Logging" Version="10.0.8" />
		<PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.8" />
	</ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Aiel\Aiel.csproj" />
        <ProjectReference Include="..\..\src\Aiel.Data.Dapper\Aiel.Data.Dapper.csproj" />
        <ProjectReference Include="..\..\src\Aiel.Testing\Aiel.Testing.csproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Update="coverlet.collector" Version="10.0.1" />
      <PackageReference Update="FluentAssertions" Version="8.10.0" />
      <PackageReference Update="Microsoft.NET.Test.Sdk" Version="18.6.0" />
    </ItemGroup>

</Project>
