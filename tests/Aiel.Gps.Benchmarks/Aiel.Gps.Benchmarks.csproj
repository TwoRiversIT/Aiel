<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace />
		<AssemblyName>Aiel.Gps.Benchmarks</AssemblyName>
		<TargetFrameworks>net10.0</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<IsPackable>false</IsPackable>
		<SignAssembly>false</SignAssembly>
		<NoWarn>$(NoWarn);VSTHRD200</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="BenchmarkDotNet" Version="0.15.8" />
	</ItemGroup>

	<ItemGroup>
		<!-- v3: Current Aiel.Gps implementation -->
		<ProjectReference Include="..\..\src\Aiel.Gps\Aiel.Gps.csproj" />
		<!-- v4: High-Performance implementation -->
		<ProjectReference Include="..\..\src\Aiel.Gps.HP\Aiel.Gps.HP.csproj" />
		<!-- Test data resources -->
		<ProjectReference Include="..\Aiel.Gps.IntegrationTests\Aiel.Gps.IntegrationTests.csproj">
			<IncludeAssets>compile</IncludeAssets>
			<ExcludeAssets>runtime;build;native;contentfiles;analyzers;buildtransitive</ExcludeAssets>
		</ProjectReference>
	</ItemGroup>

</Project>
