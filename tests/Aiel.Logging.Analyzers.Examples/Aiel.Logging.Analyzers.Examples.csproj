<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace />
		<TargetFramework>net10.0</TargetFramework>
		<NoWarn>$(NoWarn);SYSLIB1014;SYSLIB1015;CA2017</NoWarn>
		<!--
		This project is a SAMPLE only.  It deliberately contains VIOLATIONS
		in SampleViolations.cs to show what AIEL001-005 look like in practice.
		The compliant pattern is shown in SampleCompliant.cs.
		-->
	</PropertyGroup>

	<ItemGroup>
		<!-- Reference the real Microsoft.Extensions.Logging package. -->
		<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.8" />
	</ItemGroup>

	<!--
    Plug in a custom EventIds enum via MSBuild.
    In a real project this would reference the NuGet packages; here we use
    project references so the sample builds inside the solution.
	-->
	<PropertyGroup>
		<!--
		Override the default AielEventIds type name.
		The template demonstrates its own AielEventIds, so we leave this
		commented out — the default (Aiel.Logging.AielEventIds) applies.

		To use your own enum, uncomment and set your fully-qualified type name:
        <AielEventIdsType>Acme.Logging.AcmeEventIds</AielEventIdsType>
		-->
	</PropertyGroup>

	<!--
	In a real Aiel module you would reference the NuGet packages:
	<PackageReference Include="Aiel.Logging.Analyzers" Version="1.0.0" />
	<PackageReference Include="Aiel.Logging.CodeFixes"  Version="1.0.0" />
	For this template we reference the projects directly so it builds
	as part of the solution without a NuGet feed.
	-->
	<ItemGroup>
		<ProjectReference Include="..\..\src\Aiel.Logging.Analyzers\Aiel.Logging.Analyzers.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\..\src\Aiel.Logging.CodeFixes\Aiel.Logging.CodeFixes.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
	</ItemGroup>

</Project>
