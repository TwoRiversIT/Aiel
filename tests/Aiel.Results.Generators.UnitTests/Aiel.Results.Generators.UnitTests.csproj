	</ItemGroup>

	<ItemGroup>
	  <PackageReference Update="coverlet.collector" Version="10.0.1" />
	  <PackageReference Update="FluentAssertions" Version="8.10.0" />
	  <PackageReference Update="Microsoft.NET.Test.Sdk" Version="18.6.0" />
	</ItemGroup>

</Project>
