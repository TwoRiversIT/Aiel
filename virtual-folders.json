{
  "solutionFolders": {
    "/dev/": {
      "path": ".",
      "include": [],
      "exclude": [
        "*.slnx"
      ]
    },
    "/docs/": {
      "path": "docs",
      "recurse": true,
      "include": [
        "**/*.md"
      ]
    },
    "/.github/": {
      "path": ".github",
      "recurse": true,
      "include": [
        "**/*.md",
        "**/*.yml"
      ]
    }
  }
}
